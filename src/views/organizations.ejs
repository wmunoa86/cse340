<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <p>Here are a few of our partner organizations:</p>
        <p><a href="/new-organization">Add New Organization</a></p>
        <ul>
            <% organizations.forEach(organization=> { %>
                <li><img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo"><a
                        href="/organization/<%= organization.organization_id %>"><strong>
                            <%= organization.name %>
                        </strong></a>: <%= organization.contact_email %>
                </li>
                <% }); %>
        </ul>
    </main>
    <%- include('partials/footer') %>