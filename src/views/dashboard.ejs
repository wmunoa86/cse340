<%- include('partials/header') %>

<section>
    <h1>Dashboard</h1>
    <p>Welcome, <strong><%= user.name %></strong>!</p>
    <p>Email: <%= user.email %></p>
    <% if (user && user.role_name === 'admin') { %>
        <p><a href="/users">View All Users</a></p>
    <% } %>
    <p><a href="/logout">Log out</a></p>
</section>

<section>
    <h2>My Volunteering Projects</h2>
    <% if (volunteerProjects.length === 0) { %>
        <p>You have not signed up for any projects yet. <a href="/projects">Browse projects</a> to get started.</p>
    <% } else { %>
        <ul>
            <% volunteerProjects.forEach(project => { %>
                <li>
                    <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                    &mdash; <%= project.organization_name %>
                    &mdash; <%= new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' }) %>
                    <form action="/project/<%= project.project_id %>/unvolunteer" method="POST" style="display:inline;">
                        <button type="submit">Remove</button>
                    </form>
                </li>
            <% }) %>
        </ul>
    <% } %>
</section>

<%- include('partials/footer') %>
